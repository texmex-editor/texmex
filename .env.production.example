# Kopie nach .env.production (nicht committen) und Werte setzen.
# Start (Interpolation der Variablen im Compose-File):
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Öffentliche Origin der Web-Oberfläche (Schema + Host + Port, exakt wie im Browser).
# Bei diesem Stack typisch http://DEINE_DOMAIN oder http://SERVER_IP:HTTP_PORT
ALLOWED_ORIGINS=http://localhost:8080

# Npgsql-Connection-String für den ASP.NET-Server (Host=db = Postgres-Service im Compose).
# Muss zu POSTGRES_* unten passen.
DATABASE_URL=Host=db;Port=5432;Database=texmex;Username=texmex;Password=ÄNDERE_MICH

# Postgres-Container (nur intern; Ports standardmäßig nicht nach außen gemappt)
POSTGRES_USER=texmex
POSTGRES_PASSWORD=ÄNDERE_MICH
POSTGRES_DB=texmex

# Host-Port für Nginx (HTTP). Für 80: HTTP_PORT=80
HTTP_PORT=8080

# Optional: Basis-URL für REST-Client im gebauten Frontend (Build-Arg).
# Leer lassen = relative URLs /api/... (empfohlen bei diesem Nginx-Setup).
VITE_API_BASE_URL=http://localhost:8080

# Optional: interne URL des LaTeX-Compilers (Service-Name im Compose-Netz)
LATEX_COMPILER_URL=http://latex-compiler:9000
