# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173

# URL of the LaTeX compiler service (internal Docker network)
LATEX_COMPILER_URL=http://latex-compiler:9000

# Directory for persistent data (Yjs documents)
DATA_DIR=/data

# Port the server listens on
PORT=3000

# PostgreSQL connection string (Npgsql format for C#)
DATABASE_URL=Host=db;Port=5432;Database=texmex;Username=texmex;Password=texmex
